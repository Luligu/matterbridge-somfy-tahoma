# .gitignore 1.0.1
# This file specifies intentionally untracked directories and files that Git should ignore.

# Specific directories that should be ignored
.cache/
build/
coverage/
dist/
jest/
node_modules/
temp/

# Specific files that should be ignored
*.backup
*.heapsnapshot
*.heapprofile
*.tsbuildinfo
*.tgz
*.log

# Package specific directories and files that should be ignored

users-logs/
